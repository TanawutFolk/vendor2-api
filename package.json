  "main": "index.js",
  "scripts": {
    "dev_": "cross-env NODE_ENV=development esr src/index.ts",
    "dev__": "cross-env NODE_ENV=development ts-node-dev --respawn --transpile-only --require tsconfig-paths/register src/index.ts",
    "dev": "cross-env NODE_ENV=development bun --watch src/index.ts",
    "dev:prod": "cross-env NODE_ENV=production tsx watch src/index.ts",
    "dev_not_use": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "build:prod": "npm run format && npm run lint && cross-env NODE_ENV=production tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
    "start:prod": "cross-env NODE_ENV=production node -r tsconfig-paths/register dist/index.js",
    "build:azure": "npm run lint && cross-env NODE_ENV=azure tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
    "start:azure": "cross-env NODE_ENV=azure node -r tsconfig-paths/register dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write 'src/**/*.{js,ts,tsx}'"
  },
